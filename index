// ═══════════════════════════════════════════════════════════
// CHAT
// ═══════════════════════════════════════════════════════════
function renderChat(containerId, messages) {
  const el = document.getElementById(containerId);
  if (!el) return;
  const wasBottom = el.scrollHeight - el.scrollTop <= el.clientHeight + 40;
  el.innerHTML = '';
  messages.forEach(m => {
    const div = document.createElement('div');
    div.className = 'chat-msg ' + (m.type || 'msg-normal');
    if (m.type === 'msg-system') {
      div.innerHTML = `<em>${m.text}</em>`;
    } else {
      div.innerHTML = `<div class="msg-author">${m.author || '?'}</div><div>${m.text}</div>`;
    }
    el.appendChild(div);
  });
  if (wasBottom) el.scrollTop = el.scrollHeight;
}

function sendChat(channel, text, type='msg-normal') {
  if (!text.trim()) return;
  if (!gameState.chat) gameState.chat = [];
  const me = getMe();
  if (me?.silenced && channel !== 'wolf') {
    toast('Du wurdest zum Schweigen gebracht!', 'red');
    return;
  }
  gameState.chat.push({
    channel,
    type,
    author: myName,
    text: text.trim(),
    ts: Date.now()
  });
  saveGame();
  // Mark unread if not on chat pane
  markChatUnread();
}

function sendLobbyChat() {
  const inp = document.getElementById('lobby-chat-input');
  sendChat('lobby', inp.value);
  inp.value = '';
  renderLobby();
}

function sendGameChat() {
  const inp = document.getElementById('game-chat-input');
  const me = getMe();
  const isWolf = me?.role === 'werwolf' || me?.role === 'alphawerwolf';
  const channel = (gameState.phase === 'night' && isWolf) ? 'wolf' : 'day';
  sendChat(channel, inp.value, isWolf && gameState.phase === 'night' ? 'msg-wolf' : 'msg-normal');
  inp.value = '';
  renderGame();
}

function addLog(msg) {
  if (!gameState.log) gameState.log = [];
  gameState.log.push({ text: msg, ts: Date.now() });
}

// ═══════════════════════════════════════════════════════════
// START GAME
// ═══════════════════════════════════════════════════════════
function startGame() {
  if (!isHost) return;
  const players = gameState.players;
  if (players.length < 4) { toast('Mindestens 4 Spieler benötigt', 'red'); return; }
  // Show pre-game info overlay first; actual start happens in confirmStartGame()
  showPregameInfo(true);
}

function confirmStartGame() {
  hidePregameInfo();
  const players = gameState.players;
  if (players.length < 4) { toast('Mindestens 4 Spieler benötigt', 'red'); return; }

  // Build role pool
  const pool = [];
  Object.keys(gameState.roleConfig).forEach(key => {
    const count = gameState.roleConfig[key] || 0;
    for (let i = 0; i < count; i++) pool.push(key);
  });

  // Shuffle & assign
  const shuffled = pool.sort(() => Math.random() - 0.5);
  players.forEach((p, i) => {
    p.role = shuffled[i] || 'dorfbewohner';
    p.alive = true;
    p.silenced = false;
    p.inLove = false;
    p.lovePartner = null;
    p.protected = false;
    p.trapped = false;
  });

  gameState.phase = 'night';
  gameState.day = 1;
  gameState.wolfTarget = null;
  gameState.nightActions = {};
  gameState.votes = {};
  gameState.voteActive = false;
  gameState.pendingKills = [];
  gameState.witchUsedHeal = false;
  gameState.witchUsedKill = false;
  gameState.foxActive = true;
  gameState.dorfaeltesterUsed = 0;
  gameState.mayor = null;

  addLog('Das Spiel hat begonnen!');

  // Mayor election first
  gameState.phase = 'mayorvote';
  saveGame();
  renderGame();
  showScreen('screen-game');

  // Kick off narrator (host only)
  if (isHost) {
    setTimeout(startNarrator, 800);
  }
}

