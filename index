function autoCountMayorVotes() {
  const fresh = loadGame();
  gameState = fresh;

  // Count votes
  const counts = {};
  Object.keys(gameState.votes || {}).filter(k => k.startsWith('mayor_')).forEach(k => {
    const v = gameState.votes[k];
    counts[v] = (counts[v] || 0) + 1;
  });

  // If no votes at all, pick randomly
  let winner = null, max = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > max) { max = counts[id]; winner = id; } });
  if (!winner) winner = gameState.players[Math.floor(Math.random() * gameState.players.length)].id;

  gameState.mayor = winner;
  const mayorPlayer = gameState.players.find(p => p.id === winner);
  gameState.players.forEach(p => { p.isMayor = (p.id === winner); });
  gameState.votes = {};

  addLog(`👑 ${mayorPlayer?.name} wurde zum Bürgermeister gewählt!`);
  narratorSay(`👑 ${mayorPlayer?.name} führt nun das Dorf als Bürgermeister. Seine Stimme zählt doppelt!`);

  // Close mayor panel for all clients
  document.getElementById('night-action-panel').style.display = 'none';
  markActionBadge(false);

  // Brief celebration, then start Night 1
  showNarratorOverlay('👑', mayorPlayer?.name + ' ist Bürgermeister!',
    'Das Dorf hat gesprochen. Nun bricht die erste Nacht herein...', '', 4);
  saveGame();

  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    hideNarratorOverlay();
    beginNight();
  }, 4500);
}

// ── NIGHT PHASE ───────────────────────────────────────────────
function beginNight() {
  const fresh = loadGame();
  gameState = fresh;

  gameState.phase = 'night';
  gameState.nightActions = {};
  gameState.wolfTarget = null;
  gameState.players.forEach(p => { p.protected = false; p.silenced = false; });
  gameState.voteActive = false;
  gameState.votes = {};

  updateNarratorStatusText(`Nacht ${gameState.day}`);
  addLog(`🌙 Nacht ${gameState.day} beginnt. Das Dorf schläft...`);
  narratorSay(`🌙 Die Nacht senkt sich über das Dorf. Alle schließen die Augen... niemand schaut auf.`);
  saveGame();

  // Build steps for roles that actually exist in this game
  nightSteps = NIGHT_SEQUENCE.filter(step => {
    const roleInGame = gameState.players.some(p =>
      p.alive && (p.role === step.role || step.alsoFor.includes(p.role))
    );
    // Amor only acts in night 1
    if (step.onlyNight1 && gameState.day > 1) return false;
    // Skip wolf duplicates (werwolf entry covers alphawerwolf via alsoFor)
    if (step.role === 'alphawerwolf') return false;
    return roleInGame;
  });

  nightStepIndex = 0;

  // Show night opening overlay
  showNarratorOverlay(
    '🌙',
    `Nacht ${gameState.day}`,
    'Das Dorf schläft. Die Dunkelheit legt sich über die Straßen...',
    'night',
    3,
    nightSteps.map((_, i) => 'todo')
  );

  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    runNextNightStep();
  }, 3500);
}

function runNextNightStep() {
  // All steps done → go to dawn
  if (nightStepIndex >= nightSteps.length) {
    endNight();
    return;
  }

  const fresh = loadGame();
  gameState = fresh;

  const step = nightSteps[nightStepIndex];
  const dots = nightSteps.map((_, i) =>
    i < nightStepIndex ? 'done' : i === nightStepIndex ? 'active' : ''
  );

  // Check if any alive player has this role
  const eligible = gameState.players.filter(p =>
    p.alive && (p.role === step.role || (step.alsoFor && step.alsoFor.includes(p.role)))
  );

  if (eligible.length === 0) {
    // No player with this role alive, skip
    nightStepIndex++;
    runNextNightStep();
    return;
  }

  const roleObj = ROLES[step.role];
  const isMyStep = eligible.some(p => p.id === myId);

  updateNarratorStatusText(step.label);
  saveGame();

  // Show narrator overlay to all
  showNarratorOverlay(
    step.icon,
    step.label,
    getNightStepFlavourText(step.role, eligible, gameState),
    step.role === 'werwolf' || step.role === 'alphawerwolf' ? 'wolf' : 'night',
    step.duration,
    dots
  );

  // If it's my role → show action panel
  if (isMyStep) {
    // Small delay so overlay is visible first
    setTimeout(() => {
      hideNarratorOverlay();
      showNightActionUI();
      startActionTimerBar(getNightDuration(step.duration));
      switchPane('players');
    }, 1200);
  }

  narratorSay(`${step.icon} ${step.label}...`);

  clearTimeout(narratorTimer);
  const adjustedDuration = getNightDuration(step.duration);
  narratorTimer = setTimeout(() => {
    document.getElementById('night-action-panel').style.display = 'none';
    markActionBadge(false);
    hideNarratorOverlay();
    nightStepIndex++;
    if (step.role === 'werwolf' || step.role === 'alphawerwolf') {
      autoResolveWolfVote();
    }
    runNextNightStep();
  }, adjustedDuration * 1000 + 1200);
}

function autoResolveWolfVote() {
  const fresh = loadGame();
  gameState = fresh;
  if (!gameState.nightActions) gameState.nightActions = {};

  const wolfVotes = gameState.nightActions.wolfVotes || {};
  const counts = {};
  Object.values(wolfVotes).forEach(({ target, weight }) => {
    counts[target] = (counts[target] || 0) + weight;
  });

  // If no votes cast → wolves pick randomly
  const targets = gameState.players.filter(p =>
    p.alive && p.role !== 'werwolf' && p.role !== 'alphawerwolf'
  );

  let winner = null, maxV = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > maxV) { maxV = counts[id]; winner = id; } });
  if (!winner && targets.length > 0) {
    winner = targets[Math.floor(Math.random() * targets.length)].id;
  }

  if (winner) {
    gameState.wolfTarget = winner;
    const tp = gameState.players.find(p => p.id === winner);
    addLog(`🐺 Die Wölfe haben ihr Opfer gewählt.`);
  }
  saveGame();
}

function getNightStepFlavourText(role, eligible, gs) {
  const names = eligible.map(p => p.name).join(' und ');
  const flavour = {
    amor:           `${names} schleicht durch die Nacht und zieht unsichtbare Pfeile auf...`,
    seherin:        `${names} öffnet ihr inneres Auge und sucht die Wahrheit in der Dunkelheit...`,
    doktor:         `${names} schnappt seinen Koffer und schleicht zu einem Haus, um zu schützen...`,
    dorfmatratze:   `${names} macht sich leise auf den Weg zu einem anderen Haus für die Nacht...`,
    biestjaeger:    `${names} hält inne und platziert heimlich eine tödliche Falle...`,
    fuchs:          `${names} wittert in der Nacht und spürt etwas Verdächtiges auf...`,
    detektiv:       `${names} beobachtet aus dem Schatten und analysiert zwei Verdächtige...`,
    dorfaeltester:  `${names} greift tief in seine Weisheit und neutralisiert eine Bedrohung...`,
    alte_schachtel: `${names} flüstert einen alten Fluch – einer wird schweigen müssen...`,
    werwolf:        `${names} öffnen die Augen! Die Wölfe erkennen sich und wählen ihr Opfer...`,
    hexe:           `${names} studiert ihre Tränke beim schwachen Mondlicht. Heilen oder töten?`,
    serienmoerder:  `Eine Schattengestalt streicht durch die Gassen... niemand ist sicher.`,
    brandstifter:   `Der Geruch von Benzin liegt in der Luft. Jemand plant Schlimmeres...`,
    schmied:        `${names} wirft eine Münze – das Schicksal entscheidet...`,
    saeufer:        `${names} torkelt durch die Nacht, unantastbar im Rausch...`,
  };
  return flavour[role] || `${names} handelt im Verborgenen...`;
}

// ── DAWN / DAY PHASE ──────────────────────────────────────────
function endNight() {
  const fresh = loadGame();
  gameState = fresh;

  // Apply wolf kill
  let killedName = null;
  if (gameState.wolfTarget) {
    const tp = gameState.players.find(p => p.id === gameState.wolfTarget);
    if (tp && tp.alive) {
      // Dorfmatratze redirect check
      const dmVisit = gameState.nightActions?.dorfmatratzeVisit;
      if (dmVisit === gameState.wolfTarget) {
        const dm = gameState.players.find(p => p.role === 'dorfmatratze' && p.alive);
        if (dm) {
          handleDeath(dm, 'wolf');
          killedName = dm.name;
          addLog(`💃 Die Dorfmatratze hat ${tp.name} geschützt und wurde selbst gefressen!`);
        }
      } else if (tp.protected) {
        addLog(`🛡️ ${tp.name} wurde in der Nacht angegriffen, aber geschützt!`);
        narratorSay(`🛡️ Die Dunkelheit hatte jemanden im Visier – doch der Doktor war einen Schritt schneller. Eine Seele wurde gerettet!`);
      } else if (tp.role === 'verfluchter_dorfbewohner') {
        tp.role = 'werwolf';
        addLog(`😈 ${tp.name} wurde verwandelt! Er ist nun ein Werwolf!`);
        narratorSay(`😈 Die Krallen der Wölfe haben ${tp.name} gestreift... und das Dunkel hat ihn verschluckt. Er erwacht als Wolf!`);
      } else {
        handleDeath(tp, 'wolf');
        killedName = tp.name;
      }
    }
    gameState.wolfTarget = null;
  }

  gameState.phase = 'day';
  gameState.nightActions = {};
  gameState.players.forEach(p => { p.protected = false; p.silenced = false; });

  checkWinCondition();
  saveGame();

  if (gameState.phase === 'ended') {
    hideNarratorOverlay();
    showResult(gameState.winner);
    return;
  }

  updateNarratorStatusText(`Tag ${gameState.day}`);

  // Dawn announcement
  const dawnText = killedName
    ? `Die Sonne geht auf. Das Dorf erwacht. Doch auf dem Dorfplatz liegt ${killedName}... ein schrecklicher Anblick. Ein weiteres Opfer der Werwölfe.`
    : `Die Sonne geht auf. Das Dorf erwacht. Diesmal hat niemand sein Leben verloren – doch die Bedrohung lauert noch immer.`;

  addLog(`☀️ Tag ${gameState.day} beginnt.${killedName ? ` ${killedName} wurde von den Werwölfen getötet!` : ' Heute Nacht starb niemand.'}`);
  narratorSay(killedName
    ? `☀️ Die Nacht ist vorbei. ${killedName} wurde von den Werwölfen getötet. Trauer liegt über dem Dorf.`
    : `☀️ Die Nacht ist vorbei. Heute hat jemand überlebt. Das Dorf atmet auf – aber für wie lange?`);

  saveGame();

  showNarratorOverlay(
    killedName ? '💀' : '☀️',
    killedName ? `${killedName} ist gestorben` : 'Eine ruhige Nacht',
    dawnText,
    'day',
    5
  );

  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    hideNarratorOverlay();
    startDayPhase();
  }, 5500);
}

// ── DAY DISCUSSION + VOTE ─────────────────────────────────────
function startDayPhase() {
  const fresh = loadGame();
  gameState = fresh;

  updateNarratorStatusText('Diskussion');

  // Narrate discussion period
  const discussionTime = getDiscussionDuration();
  const discMins = Math.floor(discussionTime/60), discSecs = discussionTime%60;
  const discLabel = discMins>0 ? (discSecs>0?`${discMins}:${String(discSecs).padStart(2,'0')} Min`:`${discMins} Min`) : `${discussionTime}s`;
  narratorSay(`☀️ Das Dorf diskutiert. Ihr habt ${discLabel} Zeit. Wer ist der Wolf unter euch?`);
  addLog(`💬 Diskussionsphase: ${discussionTime} Sekunden.`);
  saveGame();

  // Show narrator status
  document.getElementById('narrator-status').style.display = '';
  document.getElementById('narrator-status-text').textContent = `Diskussion (${discussionTime}s)`;

  // Countdown for discussion
  let disc = discussionTime;
  const discInterval = setInterval(() => {
    disc--;
    const el = document.getElementById('narrator-status-text');
    if (el) el.textContent = `Diskussion (${disc}s)`;
    if (disc <= 30 && disc % 10 === 0) {
      narratorSay(`⏳ Noch ${disc} Sekunden zum Diskutieren...`);
      saveGame();
    }
    if (disc <= 0) {
      clearInterval(discInterval);
      startNarratorVote();
    }
  }, 1000);
}

function startNarratorVote() {
  const fresh = loadGame();
  gameState = fresh;

  hasVoted = false;
  updateNarratorStatusText('Abstimmung');

  narratorSay(`🗳️ Die Abstimmung beginnt! Wer soll heute gelyncht werden? Ihr habt 60 Sekunden.`);
  addLog(`🗳️ Abstimmung beginnt!`);

  gameState.voteActive = true;
  gameState.votes = {};
  const voteDur = getVoteDuration();
  voteTotal = voteDur;
  gameState.voteDeadline = Date.now() + voteDur * 1000;
  saveGame();

  // Show vote panel
  document.getElementById('vote-panel').style.display = '';
  const endBtn = document.getElementById('vote-end-btn');
  if (endBtn) endBtn.style.display = isHost ? '' : 'none';
  startVoteTimer();

  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    endNarratorVote();
  }, (voteDur + 2) * 1000);
}

function endNarratorVote() {
  clearTimeout(narratorTimer);
  if (voteInterval) clearInterval(voteInterval);
  if (!gameState.voteActive) return; // already ended

  const fresh = loadGame();
  gameState = fresh;

  gameState.voteActive = false;
  document.getElementById('vote-panel').style.display = 'none';

  // Count (with mayor double vote)
  const counts = {};
  getAlive().forEach(p => counts[p.id] = 0);
  Object.entries(gameState.votes || {}).forEach(([voter, target]) => {
    if (counts[target] !== undefined) counts[target]++;
    else counts[target] = 1;
    // Mayor gets extra vote
    const me2 = gameState.players.find(p => p.id === voter);
    if (me2?.isMayor && voter !== 'mayor_extra') {
      if (counts[target] !== undefined) counts[target]++;
    }
  });

  let winner = null, maxV = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > maxV) { maxV = counts[id]; winner = id; } });

  if (winner && maxV > 0) {
    const killed = gameState.players.find(p => p.id === winner);
    if (killed && killed.alive) {
      const roleName = ROLES[killed.role]?.name || '?';
      handleDeath(killed, 'lynched');
      addLog(`🗳️ ${killed.name} wurde mit ${maxV} Stimme(n) gelyncht.`);
      narratorSay(`🗳️ Das Dorf hat gesprochen: ${killed.name} (${roleName}) wird gelyncht! ${maxV} Stimme(n).`);

      showNarratorOverlay(
        '⚖️',
        `${killed.name} wurde gelyncht`,
        `Das Dorf hat ${killed.name} schuldig befunden. Er/Sie war: ${roleName}.`,
        '',
        4
      );
    } else {
      narratorSay('🗳️ Die Abstimmung brachte kein Ergebnis.');
      showNarratorOverlay('🤷', 'Unentschieden', 'Das Dorf konnte sich nicht einigen. Niemand wird heute gelyncht.', '', 3);
    }
  } else {
    narratorSay('🗳️ Zu wenige Stimmen. Niemand wird heute gelyncht.');
    showNarratorOverlay('🤷', 'Keine Abstimmung', 'Das Dorf schwieg. Niemand wurde heute gelyncht.', '', 3);
  }

  gameState.votes = {};
  checkWinCondition();
  saveGame();

  if (gameState.phase === 'ended') {
    clearTimeout(narratorTimer);
    narratorTimer = setTimeout(() => {
      hideNarratorOverlay();
      showResult(gameState.winner);
    }, 4500);
    return;
  }

  // Check if new mayor needed
  if (gameState.needNewMayor) {
    clearTimeout(narratorTimer);
    narratorTimer = setTimeout(() => {
      hideNarratorOverlay();
      runNewMayorVote();
    }, 4500);
    return;
  }

  // Transition to next night
  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    hideNarratorOverlay();
    gameState.day++;
    saveGame();
    beginNight();
  }, 4500);
}

// ── NEW MAYOR ELECTION (mid-game) ────────────────────────────
function runNewMayorVote() {
  const fresh = loadGame();
  gameState = fresh;
  gameState.needNewMayor = false;
  gameState.phase = 'mayorvote';
  gameState.votes = {};
  updateNarratorStatusText('Neue Bürgermeisterwahl');

  narratorSay(`👑 Der Bürgermeister ist gestorben. Das Dorf muss einen neuen wählen!`);
  addLog(`👑 Neue Bürgermeisterwahl!`);
  saveGame();

  showNarratorOverlay('👑', 'Neue Bürgermeisterwahl', 'Das Dorf benötigt Führung. Wählt einen neuen Bürgermeister!', '', 0);

  // Show mayor vote UI to all clients via phase change
  // Give 20 seconds
  clearTimeout(narratorTimer);
  narratorTimer = setTimeout(() => {
    hideNarratorOverlay();
    autoCountMayorVotes();
    // After mayor is set, advance day and go to night
    setTimeout(() => {
      gameState.day++;
      saveGame();
      beginNight();
    }, 3000);
  }, 20000);
}

// ── Narrator status text helper ────────────────────────────────
function updateNarratorStatusText(text) {
  const el = document.getElementById('narrator-status-text');
  if (el) el.textContent = `Erzähler: ${text}`;
  document.getElementById('narrator-status').style.display = '';
}

// ═══════════════════════════════════════════════════════════
// CONNECTION STATUS UI
// ═══════════════════════════════════════════════════════════
function showConnectionStatus(msg) {
  let el = document.getElementById('conn-status');
  if (!el) {
    el = document.createElement('div');
    el.id = 'conn-status';
    el.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:9990;background:var(--deep);border-bottom:1px solid var(--gold);padding:10px 16px;font-family:Cinzel,serif;font-size:0.78rem;color:var(--gold);text-align:center;display:flex;align-items:center;justify-content:center;gap:8px;';
    el.innerHTML = '<div style="width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin 0.8s linear infinite"></div><span id="conn-status-text"></span>';
    document.body.appendChild(el);
  }
  document.getElementById('conn-status-text').textContent = msg;
  el.style.display = 'flex';
}

function hideConnectionStatus() {
  const el = document.getElementById('conn-status');
  if (el) el.style.display = 'none';
}

// ── Share button helper ────────────────────────────────────
function shareGameCode() {
  const url = location.href.split('?')[0] + '?code=' + gameCode;
  if (navigator.share) {
    navigator.share({ title: '🐺 Werwolf Online', text: 'Spielcode: ' + gameCode, url }).catch(() => {});
  } else {
    navigator.clipboard?.writeText(url).then(() => toast('Link kopiert!', 'green')).catch(() => {
      toast('Code: ' + gameCode, '');
    });
  }
}

// ── Handle ?code= in URL (deep link) ──────────────────────
function checkUrlCode() {
  const params = new URLSearchParams(location.search);
  const code = params.get('code');
  if (code) {
    document.getElementById('join-code-input').value = code.toUpperCase();
    showJoinGame();
    toast('Code eingefügt: ' + code.toUpperCase(), 'green');
  }
}

// ── Firebase disconnect cleanup ────────────────────────────
window.addEventListener('beforeunload', () => {
  if (fbUnsubscribe) fbUnsubscribe();
  // Optionally remove player from lobby on disconnect
  if (gameState && gameState.phase === 'lobby' && myId) {
    try {
      gameState.players = gameState.players.filter(p => p.id !== myId);
      if (firebaseReady && db) db.ref(fbGamePath()).set(gameState);
    } catch(e) {}
  }
});

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
showScreen('screen-landing');
checkUrlCode();

// Show Firebase connection indicator
if (firebaseReady) {
  db.ref('.info/connected').on('value', snap => {
    const connected = snap.val() === true;
    const indicator = document.getElementById('firebase-indicator');
    if (indicator) {
      indicator.textContent = connected ? '🟢 Online' : '🔴 Offline';
      indicator.style.color = connected ? '#7dffa0' : '#ff9090';
    }
  });
}
