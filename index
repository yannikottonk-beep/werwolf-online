// ═══════════════════════════════════════════════════════════
// REAL-TIME UPDATE HANDLER (Firebase callback)
// ═══════════════════════════════════════════════════════════

// Called every time Firebase pushes an update
function onRemoteUpdate(fresh) {
  if (!fresh) return;
  const prevPhase   = gameState?.phase;
  const prevDay     = gameState?.day;
  const prevChatLen = gameState?.chat?.length || 0;

  gameState = fresh;

  // Badge new chat messages from others
  const newChatLen = gameState.chat?.length || 0;
  if (newChatLen > prevChatLen && gameState.phase !== 'lobby') {
    const newMsg = gameState.chat[gameState.chat.length - 1];
    if (newMsg && newMsg.author !== myName) markChatUnread();
  }

  if (gameState.phase === 'lobby') {
    renderLobby();
  } else if (['day','night','mayorvote'].includes(gameState.phase)) {
    renderGame();
    if (prevPhase !== gameState.phase || prevDay !== gameState.day) {
      onPhaseChange(prevPhase);
    }
    if (gameState.voteActive) {
      updateVoteUI();
      if (!isHost && !voteInterval) startVoteTimer();
    }
    if (gameState.phase === 'mayorvote' && !gameState.votes?.['mayor_'+myId]) {
      const panel = document.getElementById('night-action-panel');
      if (panel && panel.style.display === 'none') {
        const me = getMe();
        if (me && me.alive) startMayorVote();
      }
    }
  } else if (gameState.phase === 'ended') {
    showResult(gameState.winner);
  }
}

// Kept for compatibility (narrator uses this name in a few places)
function poll() { /* no-op: Firebase handles updates via onRemoteUpdate */ }
function startPolling() { /* no-op: subscribeToGame() replaces this */ }

function onPhaseChange(prev) {
  const me = getMe();
  if (gameState.phase === 'night') {
    showNightActionIfNeeded();
  }
  if (gameState.phase === 'day' && prev === 'night') {
    // Show what happened
    renderDeathNews();
  }
  if (gameState.phase === 'mayorvote') {
    if (me && me.alive) startMayorVote();
  }
}

