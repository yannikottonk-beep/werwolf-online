// ═══════════════════════════════════════════════════════════
// TIMER SETTINGS
// ═══════════════════════════════════════════════════════════
const DEFAULT_TIMERS = {
  discussion: 60,   // seconds
  vote: 60,         // seconds
  nightMultiplier: 1 // multiplier for night action durations
};

// Stored in gameState.settings so all clients see the same timers
function getTimers() {
  return gameState?.settings || DEFAULT_TIMERS;
}

function setTimerPreset(type, value, el) {
  if (!isHost) return;
  // Update active class on presets
  const container = document.getElementById('preset-' + type);
  if (container) container.querySelectorAll('.timer-preset').forEach(b => b.classList.remove('active'));
  if (el) el.classList.add('active');

  // Update input field for discussion/vote
  if (type === 'discussion') {
    document.getElementById('timer-discussion').value = value;
    if (!gameState.settings) gameState.settings = {...DEFAULT_TIMERS};
    gameState.settings.discussion = value;
  } else if (type === 'vote') {
    document.getElementById('timer-vote').value = value;
    if (!gameState.settings) gameState.settings = {...DEFAULT_TIMERS};
    gameState.settings.vote = value;
  } else if (type === 'night') {
    if (!gameState.settings) gameState.settings = {...DEFAULT_TIMERS};
    gameState.settings.nightMultiplier = value;
  }
  saveGame();
}

function syncTimerInput(type, value) {
  if (!isHost) return;
  const v = Math.max(15, Math.min(600, parseInt(value) || 60));
  if (!gameState.settings) gameState.settings = {...DEFAULT_TIMERS};
  if (type === 'discussion') gameState.settings.discussion = v;
  if (type === 'vote') gameState.settings.vote = v;
  // Deselect all presets (custom value)
  const container = document.getElementById('preset-' + type);
  if (container) container.querySelectorAll('.timer-preset').forEach(b => b.classList.remove('active'));
  saveGame();
}

function getVoteDuration() {
  return (gameState?.settings?.vote || DEFAULT_TIMERS.vote);
}

function getDiscussionDuration() {
  return (gameState?.settings?.discussion || DEFAULT_TIMERS.discussion);
}

function getNightDuration(baseSecs) {
  const mult = gameState?.settings?.nightMultiplier || 1;
  return Math.round(baseSecs * mult);
}

// ═══════════════════════════════════════════════════════════
// VOTING (improved)
// ═══════════════════════════════════════════════════════════
let voteTotal = 0; // total duration for current vote

function toggleVote() {
  if (!isHost) return;
  if (gameState.voteActive) {
    endVote();
  } else {
    startVote();
  }
}

function startVote() {
  const dur = getVoteDuration();
  voteTotal = dur;
  gameState.voteActive = true;
  gameState.votes = {};
  gameState.voteDeadline = Date.now() + dur * 1000;
  hasVoted = false;
  voteTimeLeft = dur;

  const mins = Math.floor(dur / 60);
  const secs = dur % 60;
  const label = mins > 0 ? (secs > 0 ? `${mins}:${String(secs).padStart(2,'0')} Min` : `${mins} Min`) : `${dur}s`;
  addLog(`🗳️ Abstimmung begonnen! ${label} Zeit.`);
  saveGame();

  startVoteTimer();
  document.getElementById('vote-panel').style.display = '';
  document.getElementById('vote-toggle-btn').textContent = '⛔ Stop';
  // Show end button for host
  const endBtn = document.getElementById('vote-end-btn');
  if (endBtn) endBtn.style.display = isHost ? '' : 'none';
}

function startVoteTimer() {
  if (voteInterval) clearInterval(voteInterval);
  voteTotal = voteTotal || getVoteDuration();
  voteInterval = setInterval(() => {
    if (!gameState?.voteActive) { clearInterval(voteInterval); return; }
    const remaining = Math.max(0, Math.round((gameState.voteDeadline - Date.now()) / 1000));
    updateVoteClock(remaining, voteTotal);
    if (remaining <= 0) {
      clearInterval(voteInterval);
      if (isHost) endVote();
    }
    updateVoteUI();
  }, 500);
}

function updateVoteClock(remaining, total) {
  const timerEl = document.getElementById('vote-timer');
  const circleEl = document.getElementById('vote-clock-circle');
  const progressEl = document.getElementById('vote-progress-fill');

  if (timerEl) {
    if (remaining >= 60) {
      const m = Math.floor(remaining/60), s = remaining%60;
      timerEl.textContent = m + ':' + String(s).padStart(2,'0');
    } else {
      timerEl.textContent = remaining;
    }
  }

  if (circleEl && total > 0) {
    const circumference = 125.6;
    const pct = remaining / total;
    circleEl.style.strokeDashoffset = circumference * (1 - pct);
    circleEl.className = 'vote-clock-fill ' + (remaining < total * 0.25 ? 'urgent' : 'ok');
  }

  if (progressEl && total > 0) {
    const pct = (remaining / total) * 100;
    progressEl.style.width = pct + '%';
    progressEl.style.background = remaining < total * 0.25
      ? 'var(--red-bright)'
      : remaining < total * 0.5
        ? 'var(--gold)'
        : 'var(--green-bright)';
  }
}

function updateVoteUI() {
  if (!gameState?.voteActive) return;
  const el = document.getElementById('vote-bars');
  if (!el) return;
  document.getElementById('vote-panel').style.display = '';

  // Build vote counts
  const counts = {};
  const alive = getAlive();
  alive.forEach(p => counts[p.id] = 0);

  const votes = gameState.votes || {};
  Object.entries(votes).forEach(([voter, target]) => {
    // Skip mayor_extra entries for basic count display
    if (voter.startsWith('mayor_extra')) return;
    if (counts[target] !== undefined) counts[target]++;
  });

  // Mayor double-count display
  const mayorPlayer = gameState.players.find(p => p.id === gameState.mayor && p.alive);
  if (mayorPlayer && votes[mayorPlayer.id]) {
    counts[votes[mayorPlayer.id]] = (counts[votes[mayorPlayer.id]] || 0) + 1; // extra
  }

  const maxVotes = Math.max(1, ...Object.values(counts));
  const totalCast = Object.keys(votes).filter(k => !k.startsWith('mayor_extra')).length;
  const myVoteTarget = votes[myId];

  // Sort: most votes first
  const sorted = [...alive].sort((a, b) => (counts[b.id]||0) - (counts[a.id]||0));

  el.innerHTML = sorted.map(p => {
    const v = counts[p.id] || 0;
    const pct = maxVotes > 0 ? Math.round(v / maxVotes * 100) : 0;
    const isLeading = v === maxVotes && v > 0;
    const isMyChoice = myVoteTarget === p.id;
    const isMayor = p.id === gameState.mayor;
    const role = ROLES[p.role];

    return `<div class="vote-bar-row ${isMyChoice ? 'voted-for' : ''} ${isLeading ? 'leading' : ''}"
                 onclick="${!hasVoted && p.alive && p.id !== myId ? `castVote('${p.id}')` : ''}">
      <div class="vb-avatar">${role?.emoji || '🧑'}</div>
      <div class="vb-name">${p.name}${isMayor ? ' 👑' : ''}</div>
      <div class="vote-bar-track">
        <div class="vote-bar-fill ${isLeading ? 'fill-lead' : ''}" style="width:${pct}%"></div>
      </div>
      <div class="vote-count">${v}${isMayor ? '<span style="font-size:0.6rem;color:var(--gold)">×2</span>' : ''}</div>
    </div>`;
  }).join('');

  // Summary
  const statusEl = document.getElementById('vote-status');
  const countEl  = document.getElementById('vote-count-done');
  if (statusEl) statusEl.textContent = myVoteTarget
    ? 'Stimme abgegeben ✓'
    : alive.some(p => p.id === myId) ? 'Noch nicht abgestimmt' : 'Zuschauer';
  if (countEl)  countEl.textContent = totalCast + '/' + alive.length;

  // Your choice display
  const ycEl   = document.getElementById('vote-your-choice');
  const ycName = document.getElementById('vote-your-name');
  if (ycEl && ycName) {
    if (myVoteTarget) {
      const target = gameState.players.find(p => p.id === myVoteTarget);
      ycEl.style.display = '';
      ycName.textContent = target?.name || '?';
    } else {
      ycEl.style.display = 'none';
    }
  }
}

function castVote(targetId) {
  if (hasVoted) return;
  const me = getMe();
  if (!me || !me.alive || me.silenced) { toast('Du kannst nicht abstimmen!', 'red'); return; }
  if (!gameState.voteActive) { toast('Keine aktive Abstimmung', 'red'); return; }

  if (!gameState.votes) gameState.votes = {};
  gameState.votes[myId] = targetId;

  // Mayor gets double vote (stored separately for counting)
  if (me.isMayor) {
    gameState.votes['mayor_extra_' + myId] = targetId;
  }

  saveGame();
  hasVoted = true;
  const target = gameState.players.find(p => p.id === targetId);
  toast('Stimme für ' + (target?.name || '?') + ' abgegeben!', 'green');
  renderPlayersGrid();
  updateVoteUI();
  // Switch to players pane on mobile to show the vote bars
  if (window.innerWidth < 640) switchPane('players');
}

function countVotes() {
  const counts = {};
  getAlive().forEach(p => counts[p.id] = 0);
  Object.entries(gameState.votes || {}).forEach(([voter, target]) => {
    if (voter.startsWith('mayor_extra')) {
      // Extra mayor vote
      if (counts[target] !== undefined) counts[target]++;
    } else {
      if (counts[target] !== undefined) counts[target]++;
    }
  });
  return counts;
}

function endVote() {
  gameState.voteActive = false;
  clearInterval(voteInterval);
  voteInterval = null;

  const counts = countVotes();
  let winner = null, max = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > max) { max = counts[id]; winner = id; } });

  // Check for tie
  const tied = Object.keys(counts).filter(id => counts[id] === max && max > 0);

  document.getElementById('vote-panel').style.display = 'none';
  document.getElementById('vote-toggle-btn').textContent = '🗳️ Abstimmen';
  const endBtn = document.getElementById('vote-end-btn');
  if (endBtn) endBtn.style.display = 'none';

  if (tied.length > 1) {
    // Tie → mayor decides, or random
    const mayorVote = gameState.votes?.[gameState.mayor];
    if (mayorVote && tied.includes(mayorVote)) {
      winner = mayorVote;
      addLog('🗳️ Gleichstand! Bürgermeister entscheidet.');
    } else {
      winner = tied[Math.floor(Math.random() * tied.length)];
      addLog('🗳️ Gleichstand! Zufall entscheidet.');
    }
  }

  if (winner && max > 0) {
    const killed = gameState.players.find(p => p.id === winner);
    if (killed && killed.alive) {
      addLog(`⚖️ ${killed.name} wird gelyncht! (${max} Stimme${max !== 1 ? 'n' : ''})`);
      handleDeath(killed, 'lynched');
    }
  } else {
    addLog('🗳️ Abstimmung: Niemand wurde gewählt.');
  }

  gameState.votes = {};
  hasVoted = false;
  saveGame();
  checkWinCondition();
  renderGame();
}

