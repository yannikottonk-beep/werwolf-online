function endGameManual() {
  if (!isHost) return;
  if (!confirm('Spiel wirklich beenden?')) return;
  // Stop narrator
  narratorActive = false;
  clearTimeout(narratorTimer);
  if (voteInterval) clearInterval(voteInterval);
  hideNarratorOverlay();
  const fresh = loadGame();
  gameState = fresh;
  gameState.phase = 'ended';
  gameState.winner = 'village';
  saveGame();
}

function backToLanding() {
  document.getElementById('result-screen').style.display = 'none';
  if (pollInterval)   clearInterval(pollInterval);
  if (narratorTimer)  clearTimeout(narratorTimer);
  if (fbUnsubscribe)  { fbUnsubscribe(); fbUnsubscribe = null; }
  narratorActive = false;
  hideNarratorOverlay();
  gameState  = null;
  gameCode   = '';
  isHost     = false;
  showScreen('screen-landing');
}

