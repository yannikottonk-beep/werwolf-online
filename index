// ═══════════════════════════════════════════════════════════
function buildRoleConfig() {
  ['dorf','wolf','spezial'].forEach(tab => {
    const el = document.getElementById('rc-'+tab);
    el.innerHTML = '';
  });

  Object.keys(ROLES).forEach(key => {
    const role = ROLES[key];
    const val = gameState.roleConfig[key] ?? role.default;
    const div = document.createElement('div');
    div.className = 'role-config-item';
    div.innerHTML = `
      <span style="font-size:1.2rem">${role.emoji}</span>
      <span class="rc-name">${role.name}</span>
      <div class="rc-counter">
        <button onclick="changeRoleCount('${key}',-1)">−</button>
        <span class="rc-val" id="rcv-${key}">${val}</span>
        <button onclick="changeRoleCount('${key}',1)">+</button>
      </div>
    `;
    const container = document.getElementById('rc-'+role.tab);
    if (container) container.appendChild(div);
  });

  updateRoleSummary();
}

function changeRoleCount(key, delta) {
  if (!isHost) return;
  const role = ROLES[key];
  const cur = gameState.roleConfig[key] ?? role.default;
  const nv = Math.max(role.min, Math.min(role.max, cur + delta));
  gameState.roleConfig[key] = nv;
  document.getElementById('rcv-'+key).textContent = nv;
  saveGame();
  updateRoleSummary();
}

function updateRoleSummary() {
  const total = Object.keys(ROLES).reduce((s,k) => s + (gameState.roleConfig[k]||0), 0);
  const el = document.getElementById('rc-summary');
  if (el) el.textContent = `Gesamt: ${total} Rolle(n) für ${gameState.players.length} Spieler`;
}

