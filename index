// ═══════════════════════════════════════════════════════════
// PHASE TRANSITIONS
// ═══════════════════════════════════════════════════════════
function goToNight() {
  if (!isHost) return;
  const fresh = loadGame();
  gameState = fresh;

  // Apply wolf kill
  if (gameState.wolfTarget) {
    const tp = gameState.players.find(p=>p.id===gameState.wolfTarget);
    if (tp && tp.alive && !tp.protected) {
      handleDeath(tp, 'wolf');
    } else if (tp?.protected) {
      addLog(`🛡️ Jemand wurde geschützt und überlebte die Nacht.`);
    }
  }

  gameState.wolfTarget = null;
  gameState.nightActions = {};
  gameState.players.forEach(p => p.protected = false);

  // New mayor needed?
  if (gameState.needNewMayor) {
    gameState.needNewMayor = false;
    gameState.phase = 'mayorvote';
  } else {
    gameState.day++;
    gameState.phase = 'night';
  }

  addLog(gameState.phase === 'night' ? `🌙 Nacht ${gameState.day} beginnt...` : '👑 Neue Bürgermeisterwahl!');
  checkWinCondition();
  saveGame();
  renderGame();
}

function goToDay() {
  if (!isHost) return;
  const fresh = loadGame();
  gameState = fresh;

  // Apply wolf kill if pending
  if (gameState.wolfTarget) {
    const tp = gameState.players.find(p=>p.id===gameState.wolfTarget);
    if (tp && tp.alive && !tp.protected) {
      handleDeath(tp, 'wolf');
    } else if (tp?.protected) {
      addLog(`🛡️ Jemand wurde diese Nacht beschützt.`);
    }
    gameState.wolfTarget = null;
  }

  gameState.players.forEach(p => { p.protected = false; p.silenced = false; });
  gameState.phase = 'day';
  gameState.nightActions = {};
  addLog(`☀️ Tag ${gameState.day} beginnt. Das Dorf erwacht...`);
  checkWinCondition();
  saveGame();
  renderGame();
}

function hostKillPlayer() {
  if (!isHost) return;
  const fresh = loadGame();
  gameState = fresh;
  const id = document.getElementById('kill-select').value;
  if (!id) return;
  const tp = gameState.players.find(p=>p.id===id);
  if (tp) {
    handleDeath(tp, 'wolf');
    checkWinCondition();
    saveGame();
    renderGame();
    toast(`${tp.name} wurde getötet.`, 'red');
  }
}

// ═══════════════════════════════════════════════════════════
// WIN CONDITIONS
// ═══════════════════════════════════════════════════════════
function checkWinCondition() {
  const alive = getAlive();
  const wolves = alive.filter(p=>p.role==='werwolf'||p.role==='alphawerwolf');
  const villagers = alive.filter(p=>ROLES[p.role]?.team==='village');
  const solos = alive.filter(p=>ROLES[p.role]?.team==='solo');

  if (wolves.length === 0) {
    // Village wins (or solo if only one remains)
    if (solos.length === 1 && alive.length === 1) {
      gameState.winner = 'solo';
      gameState.phase = 'ended';
      addLog(`🎭 ${solos[0].name} hat als Solospieler gewonnen!`);
    } else if (gameState.winner !== 'narr') {
      gameState.winner = 'village';
      gameState.phase = 'ended';
      addLog(`🏘️ Das Dorf hat gewonnen! Alle Werwölfe sind tot.`);
    }
  } else if (wolves.length >= alive.length - wolves.length) {
    // Wolves win
    gameState.winner = 'wolf';
    gameState.phase = 'ended';
    addLog(`🐺 Die Werwölfe haben gewonnen! Sie sind in der Mehrheit.`);
  }
}

