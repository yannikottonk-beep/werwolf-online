function doNightAction(action, target) {
  const fresh = loadGame();
  gameState = fresh;
  if (!gameState.nightActions) gameState.nightActions = {};

  const me = getMe();

  switch(action) {
    case 'peek': {
      const target_player = gameState.players.find(p=>p.id===target);
      if (target_player) {
        const role = ROLES[target_player.role];
        toast(`🔮 ${target_player.name} ist: ${role?.emoji} ${role?.name}`, '');
        addLog(`🔮 Seherin hat ${target_player.name} untersucht.`);
      }
      break;
    }
    case 'protect': {
      gameState.players.forEach(p => p.protected = false);
      const tp = gameState.players.find(p=>p.id===target);
      if (tp) tp.protected = true;
      addLog(`💉 Doktor schützt jemanden.`);
      break;
    }
    case 'wolfvote': {
      if (!gameState.nightActions.wolfVotes) gameState.nightActions.wolfVotes = {};
      const weight = me?.role === 'alphawerwolf' ? 2 : 1;
      gameState.nightActions.wolfVotes[myId] = { target, weight };
      addLog(`🐺 Ein Wolf hat abgestimmt.`);

      // If host, auto-resolve wolf votes after 5s
      if (isHost) setTimeout(resolveWolfVotes, 5000);
      break;
    }
    case 'witch_heal': {
      const tp = gameState.players.find(p=>p.id===target);
      if (tp) tp.protected = true;
      gameState.witchUsedHeal = true;
      gameState.wolfTarget = null;
      addLog(`🧪 Hexe hat den Heiltrank eingesetzt.`);
      break;
    }
    case 'witch_kill': {
      const tp = gameState.players.find(p=>p.id===target);
      if (tp) {
        handleDeath(tp, 'witch');
      }
      gameState.witchUsedKill = true;
      addLog(`☠️ Hexe hat den Gifttrank eingesetzt.`);
      break;
    }
    case 'witch_pass': {
      addLog(`🧪 Hexe hat keine Tränke eingesetzt.`);
      break;
    }
    case 'love': {
      const ids = target.split(',');
      const p1 = gameState.players.find(p=>p.id===ids[0]);
      const p2 = gameState.players.find(p=>p.id===ids[1]);
      if (p1 && p2) {
        p1.inLove = true; p1.lovePartner = p2.id;
        p2.inLove = true; p2.lovePartner = p1.id;
        addLog(`💘 Amor hat ${p1.name} und ${p2.name} verliebt.`);
      }
      break;
    }
    case 'visit': {
      gameState.nightActions.dorfmatratzeVisit = target;
      const tp = gameState.players.find(p=>p.id===target);
      addLog(`💃 Dorfmatratze besucht jemanden.`);
      break;
    }
    case 'detect': {
      const ids = target.split(',');
      const p1 = gameState.players.find(p=>p.id===ids[0]);
      const p2 = gameState.players.find(p=>p.id===ids[1]);
      if (p1 && p2) {
        const same = ROLES[p1.role]?.team === ROLES[p2.role]?.team;
        toast(`🔍 ${p1.name} & ${p2.name}: ${same ? '✅ Gleiches Team' : '❌ Verschiedene Teams'}`, same?'green':'red');
        addLog(`🔍 Detektiv hat zwei Spieler untersucht.`);
      }
      break;
    }
    case 'smkill': {
      const tp = gameState.players.find(p=>p.id===target);
      if (tp && !tp.protected) {
        handleDeath(tp, 'smkill');
        addLog(`🔪 Serienmörder hat ${tp.name} getötet.`);
      }
      break;
    }
  }

  saveGame();
  document.getElementById('night-action-panel').style.display = 'none';
  const badge = document.getElementById('badge-action');
  if (badge) badge.classList.remove('show');
  switchPane('players');
  renderGame();
}

function resolveWolfVotes() {
  const fresh = loadGame();
  gameState = fresh;
  if (!gameState.nightActions?.wolfVotes) return;

  const counts = {};
  Object.values(gameState.nightActions.wolfVotes).forEach(({target, weight}) => {
    counts[target] = (counts[target]||0) + weight;
  });

  let winner = null, max = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > max) { max = counts[id]; winner = id; } });

  if (winner) {
    const tp = gameState.players.find(p=>p.id===winner);
    if (tp) {
      gameState.wolfTarget = winner;
      addLog(`🐺 Die Wölfe haben ihr Ziel gewählt: ${tp.name}`);
      // Check dorfmatratze
      const dorfmatratzeVisit = gameState.nightActions?.dorfmatratzeVisit;
      if (dorfmatratzeVisit === winner) {
        const dm = gameState.players.find(p=>p.role==='dorfmatratze'&&p.alive);
        if (dm) {
          handleDeath(dm, 'wolf');
          addLog(`💃 Dorfmatratze hat ${tp.name} geschützt und ist gestorben!`);
          gameState.wolfTarget = null;
        }
      } else if (!tp.protected) {
        // Check if cursed
        if (tp.role === 'verfluchter_dorfbewohner') {
          tp.role = 'werwolf';
          addLog(`😈 ${tp.name} wurde zum Werwolf!`);
          gameState.wolfTarget = null;
        }
      }
    }
  }

  saveGame();
}

// ═══════════════════════════════════════════════════════════
// DEATH HANDLING
// ═══════════════════════════════════════════════════════════
function handleDeath(player, cause) {
  if (!player.alive) return;
  player.alive = false;

  addLog(`💀 ${player.name} ist gestorben (${deathCauseText(cause)}).`);

  // Special death effects
  if (player.role === 'jaeger') {
    // Hunter shoots
    addLog(`🎯 Jäger ${player.name} darf noch jemanden erschießen!`);
    if (player.id === myId) {
      showHunterShot();
    }
  }

  if (player.role === 'terrorist') {
    // Kill neighbors
    const alive = getAlive();
    const idx = gameState.players.findIndex(p=>p.id===player.id);
    const neighbors = [gameState.players[idx-1], gameState.players[idx+1]].filter(p=>p&&p.alive);
    neighbors.forEach(n => { handleDeath(n, 'terrorist'); });
  }

  if (player.role === 'bloody_mary' && cause === 'lynched') {
    addLog(`🩸 Bloody Mary reißt einen Ankläger mit!`);
    // Simplification: mark for host to handle
  }

  // Lover dies
  if (player.inLove && player.lovePartner) {
    const partner = gameState.players.find(p=>p.id===player.lovePartner);
    if (partner && partner.alive) {
      addLog(`💔 ${partner.name} stirbt aus Liebeskummer!`);
      handleDeath(partner, 'love');
    }
  }

  // Mayor died → need new mayor
  if (player.isMayor) {
    addLog(`👑 Der Bürgermeister ist gestorben. Morgen wird ein neuer bestimmt!`);
    gameState.needNewMayor = true;
  }

  // Narr win check
  if (player.role === 'narr' && cause === 'lynched') {
    gameState.winner = 'narr';
    gameState.phase = 'ended';
    addLog(`🃏 Der Narr hat gewonnen! Er wurde vom Dorf gelyncht.`);
  }
}

function deathCauseText(cause) {
  const map = { wolf:'von Werwölfen', lynched:'gelyncht', witch:'Hexengift', terrorist:'Terroranschlag', love:'Liebeskummer', smkill:'Serienmörder', arson:'Brandstifter', trap:'Falle', hunter_shot:'Jägerschuss' };
  return map[cause] || cause;
}

