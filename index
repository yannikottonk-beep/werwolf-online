function startMayorVote() {
  switchPane('players');
  const panel = document.getElementById('night-action-panel');
  const title = document.getElementById('night-action-title');
  const content = document.getElementById('night-action-content');
  panel.style.display = '';
  title.textContent = '👑 Bürgermeisterwahl';
  markActionBadge(true);

  content.innerHTML = `
    <div class="text-muted text-sm mb-8">Wähle deinen Bürgermeister!</div>
    <div class="role-config-grid" style="grid-template-columns:1fr 1fr">
      ${getAlive().map(p => `
        <button class="btn btn-ghost" style="justify-content:flex-start;gap:8px" onclick="voteMayor('${p.id}')">
          🧑 ${p.name}
        </button>
      `).join('')}
    </div>
  `;
}

function voteMayor(targetId) {
  if (!gameState.votes) gameState.votes = {};
  if (gameState.votes['mayor_' + myId]) return; // already voted
  const fresh = loadGame();
  gameState = fresh;
  if (!gameState.votes) gameState.votes = {};
  gameState.votes['mayor_' + myId] = targetId;
  saveGame();
  toast('Stimme abgegeben!');
  // Close the panel for this player
  document.getElementById('night-action-panel').style.display = 'none';
  markActionBadge(false);
  // Narrator (host) auto-resolves at the right time via its own timer
}

function countMayorVotes() {
  const fresh = loadGame();
  gameState = fresh;
  const counts = {};
  Object.keys(gameState.votes).filter(k => k.startsWith('mayor_')).forEach(k => {
    const v = gameState.votes[k];
    counts[v] = (counts[v]||0) + 1;
  });
  let winner = null, max = 0;
  Object.keys(counts).forEach(id => { if (counts[id] > max) { max = counts[id]; winner = id; } });
  if (!winner) winner = gameState.players[0].id;

  gameState.mayor = winner;
  const mayorPlayer = gameState.players.find(p => p.id === winner);
  if (mayorPlayer) mayorPlayer.isMayor = true;
  gameState.players.forEach(p => { if (p.id !== winner) p.isMayor = false; });

  addLog(`👑 ${mayorPlayer?.name || '?'} wurde zum Bürgermeister gewählt!`);
  gameState.phase = 'night';
  gameState.votes = {};
  saveGame();
  document.getElementById('night-action-panel').style.display = 'none';
}

// ═══════════════════════════════════════════════════════════
// GAME RENDER
// ═══════════════════════════════════════════════════════════
function renderGame() {
  if (!gameState) return;
  const me = getMe();
  if (!me) return;

  // Phase label
  const phaseLabel = document.getElementById('game-phase-label');
  if (gameState.phase === 'day') phaseLabel.innerHTML = `<span class="badge badge-day">☀️ Tag ${gameState.day}</span>`;
  else if (gameState.phase === 'night') phaseLabel.innerHTML = `<span class="badge badge-night">🌙 Nacht ${gameState.day}</span>`;
  else if (gameState.phase === 'mayorvote') phaseLabel.innerHTML = `<span class="badge badge-day">👑 Bürgermeisterwahl</span>`;

  // Alive count
  document.getElementById('alive-count-label').textContent = `Lebend: ${getAlive().length}`;

  // My role chip
  const chip = document.getElementById('my-role-chip');
  const myRole = ROLES[me.role];
  chip.textContent = myRole ? `${myRole.emoji} ${myRole.name}` : '';
  if (me.isMayor) chip.textContent = '👑 ' + chip.textContent;

  // Mayor section
  const mayorSection = document.getElementById('mayor-section');
  const mayorPlayer = gameState.players.find(p => p.id === gameState.mayor);
  if (mayorPlayer && mayorPlayer.alive) {
    mayorSection.style.display = '';
    document.getElementById('current-mayor-name').textContent = mayorPlayer.name;
  } else {
    mayorSection.style.display = 'none';
  }

  // Players grid
  renderPlayersGrid();

  // Chat (only show messages the player can see)
  const isWolf = me.role === 'werwolf' || me.role === 'alphawerwolf';
  const chatMsgs = gameState.chat?.filter(m =>
    m.channel === 'day' ||
    m.channel === 'lobby' ||
    (m.channel === 'wolf' && isWolf)
  ) || [];
  renderChat('game-chat', chatMsgs);

  // Badge for new chat when not on chat pane
  if (currentPane !== 'chat' && chatMsgs.length > 0) {
    const badge = document.getElementById('badge-chat');
    if (badge) badge.classList.add('show');
  }

  // Log
  renderLog();

  // Role info
  renderRoleInfo(me);

  // Vote toggle button – visible only for host on day phase
  const voteToggle = document.getElementById('vote-toggle-btn');
  if (voteToggle) {
    voteToggle.style.display = (isHost && gameState.phase === 'day') ? '' : 'none';
    voteToggle.textContent = gameState.voteActive ? '⛔ Abstimmung stopp' : '🗳️ Abstimmen';
  }

  // Host controls
  const hc = document.getElementById('host-controls');
  if (hc) hc.style.display = isHost ? '' : 'none';
  if (isHost) {
    const killSelect = document.getElementById('kill-select');
    if (killSelect) {
      killSelect.innerHTML = '<option value="">— Auswählen —</option>' +
        getAlive().map(p => `<option value="${p.id}">${p.name}</option>`).join('');
    }
    const hkc = document.getElementById('host-kill-control');
    if (hkc) hkc.style.display = gameState.phase === 'night' ? '' : 'none';
  }
}

function renderPlayersGrid() {
  const container = document.getElementById('game-players');
