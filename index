function buildNightSequenceDisplay() {
  const container = document.getElementById('pg-night-sequence');
  if (!container) return;

  // Figure out which roles are in this game
  const cfg = gameState?.roleConfig || {};
  const inGame = new Set();
  Object.keys(cfg).forEach(k => { if ((cfg[k] || 0) > 0) inGame.add(k); });

  let visibleStep = 0;
  container.innerHTML = '';

  FULL_NIGHT_SEQUENCE.forEach(step => {
    // Check if this step is relevant (role or alsoFor in game)
    const present = inGame.has(step.role) || (step.alsoFor || []).some(r => inGame.has(r));
    const inactive = !present;

    if (inactive) visibleStep; // don't increment step number for inactive
    else visibleStep++;

    const typeClass = step.type === 'wolf' ? 'seq-wolf'
                    : step.type === 'solo' ? 'seq-special'
                    : '';

    const div = document.createElement('div');
    div.className = 'night-seq-item ' + typeClass + (inactive ? ' seq-inactive' : '');

    const condHtml = step.nightCondition
      ? `<span class="seq-cond ${step.onlyNight1 ? 'cond-night1' : ''}">${step.nightCondition}</span>`
      : '';

    const notInGame = inactive ? '<div class="seq-not-in-game">Nicht im Spiel</div>' : '';

    div.innerHTML = `
      ${notInGame}
      <div class="seq-num">${inactive ? '–' : visibleStep}</div>
      <div class="seq-icon">${step.icon}</div>
      <div class="seq-body">
        <div class="seq-title">
          ${step.label}
          ${condHtml}
        </div>
        <div class="seq-action">${step.action}</div>
        <div class="seq-desc">${step.flavour}</div>
      </div>
      ${!inactive ? `<div class="seq-timer">⏱ ${step.duration}s</div>` : ''}
    `;
    container.appendChild(div);
  });
}

function buildRoleCardsDisplay() {
  const container = document.getElementById('pg-role-cards');
  if (!container) return;

  const cfg = gameState?.roleConfig || {};
  container.innerHTML = '';

  const teamOrder = ['village', 'wolf', 'solo'];
  const sorted = Object.keys(ROLES).sort((a, b) => {
    const ta = teamOrder.indexOf(ROLES[a].team);
    const tb = teamOrder.indexOf(ROLES[b].team);
    return ta !== tb ? ta - tb : 0;
  });

  sorted.forEach(key => {
    const role  = ROLES[key];
    const count = cfg[key] || 0;
    if (count === 0) return; // only show roles in this game

    const teamClass = role.team === 'wolf' ? 'rc-wolf'
                    : role.team === 'solo' ? 'rc-solo'
                    : 'rc-village';

    const teamLabel = role.team === 'wolf'    ? '<span class="ric-team ric-wolf-t">🐺 Werwolf</span>'
                    : role.team === 'solo'    ? '<span class="ric-team ric-solo-t">🎭 Solo</span>'
                    : '<span class="ric-team ric-village">🏘️ Dorf</span>';

    const nightTag = ROLES[key].nightAction
      ? '<div class="ric-night-tag">🌙 Nacht-Aktion</div>'
      : '';

    // Get ability text from FULL_NIGHT_SEQUENCE or role desc
    const seqEntry = FULL_NIGHT_SEQUENCE.find(s => s.role === key);
    const abilityText = seqEntry ? seqEntry.action : role.desc;

    const card = document.createElement('div');
    card.className = `role-info-card ${teamClass}`;
    card.innerHTML = `
      <span class="ric-emoji">${role.emoji}</span>
      <div class="ric-name">${role.name}</div>
      <div class="ric-count">${count}× im Spiel</div>
      ${teamLabel}
      ${nightTag}
      <div class="ric-desc">${role.desc}</div>
      <div class="ric-ability">⚡ ${abilityText}</div>
    `;
    container.appendChild(card);
  });

  if (container.children.length === 0) {
    container.innerHTML = '<div class="text-muted text-sm text-center" style="padding:20px">Keine Rollen konfiguriert.</div>';
  }
}

