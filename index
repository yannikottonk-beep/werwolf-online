// Save gameState to Firebase (or localStorage fallback)
function saveGame() {
  gameState.lastUpdated = Date.now();
  if (firebaseReady && db) {
    db.ref(fbGamePath()).set(gameState).catch(e => {
      console.warn('[FB] set failed:', e);
      // Show error if it's a permission denied
      if (e.code === 'PERMISSION_DENIED') {
        toast('⚠️ Firebase: Regeln fehlen! Siehe Schritt 7 der Anleitung.', 'red');
      }
      localStorage.setItem(STORE_PREFIX + 'game_' + gameCode, JSON.stringify(gameState));
    });
  } else {
    localStorage.setItem(STORE_PREFIX + 'game_' + gameCode, JSON.stringify(gameState));
  }
}

// Load once (for join check) – returns a Promise
function loadGameOnce() {
  if (firebaseReady && db) {
    return db.ref(fbGamePath()).get().then(snap => snap.exists() ? snap.val() : null);
  } else {
    const raw = localStorage.getItem(STORE_PREFIX + 'game_' + gameCode);
    return Promise.resolve(raw ? JSON.parse(raw) : null);
  }
}

// Subscribe to real-time updates
function subscribeToGame(callback) {
  // Detach any previous listener
  if (fbUnsubscribe) { fbUnsubscribe(); fbUnsubscribe = null; }
  if (pollInterval)  { clearInterval(pollInterval); pollInterval = null; }

  if (firebaseReady && db) {
    const ref = db.ref(fbGamePath());
    const handler = ref.on('value', snap => {
      if (snap.exists()) callback(snap.val());
    }, err => {
      console.warn('[FB] listener error, falling back to poll:', err);
      startPollingFallback(callback);
    });
    fbUnsubscribe = () => ref.off('value', handler);
    console.log('[Firebase] Subscribed to', fbGamePath());
  } else {
    startPollingFallback(callback);
  }
}

function startPollingFallback(callback) {
  if (pollInterval) clearInterval(pollInterval);
  pollInterval = setInterval(() => {
    const raw = localStorage.getItem(STORE_PREFIX + 'game_' + gameCode);
    if (raw) callback(JSON.parse(raw));
  }, 1000);
}

