  const discCont = document.getElementById('preset-discussion');
  if (discCont) {
    discCont.querySelectorAll('.timer-preset').forEach((b, i) => b.classList.remove('active'));
    const idx = discPresets[String(s.discussion)];
    if (idx !== undefined) discCont.children[idx]?.classList.add('active');
  }

  // Update preset active states for vote
  const votePresets = {'30': 0, '60': 1, '90': 2, '120': 3};
  const voteCont = document.getElementById('preset-vote');
  if (voteCont) {
    voteCont.querySelectorAll('.timer-preset').forEach(b => b.classList.remove('active'));
    const idx = votePresets[String(s.vote)];
    if (idx !== undefined) voteCont.children[idx]?.classList.add('active');
  }

  // Night multiplier
  const nightCont = document.getElementById('preset-night');
  if (nightCont && s.nightMultiplier) {
    const nightMap = {'0.5': 0, '1': 1, '1.5': 2, '2': 3};
    nightCont.querySelectorAll('.timer-preset').forEach(b => b.classList.remove('active'));
    const idx = nightMap[String(s.nightMultiplier)];
    if (idx !== undefined) nightCont.children[idx]?.classList.add('active');
  }
}

function renderLobby() {
