<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="mobile-web-app-capable" content="yes">
<title>🐺 Werwolf Online</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

  :root {
    --night: #0d0d1a;
    --deep: #13132a;
    --card: #1a1a35;
    --border: #2e2e5e;
    --gold: #c9a227;
    --gold-light: #e8c547;
    --red: #8b1a1a;
    --red-bright: #c0392b;
    --green: #1a6b3a;
    --green-bright: #27ae60;
    --purple: #4a1a6b;
    --text: #e8e0d0;
    --muted: #8880a0;
    --wolf-red: #7a0000;
    --nav-h: 64px;
    --safe-bottom: env(safe-area-inset-bottom, 0px);
    --safe-top: env(safe-area-inset-top, 0px);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  html { height: 100%; }

  body {
    font-family: 'Crimson Text', serif;
    background: var(--night);
    color: var(--text);
    min-height: 100%;
    min-height: 100dvh;
    overflow-x: hidden;
    /* Prevent iOS text size adjustment */
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
  }

  /* Village background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(139,26,26,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(74,26,107,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(13,13,26,0.8) 0%, transparent 100%);
    z-index: 0;
    pointer-events: none;
  }

  #village-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  #village-bg svg {
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }

  /* ── SCREENS ── */
  .app {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 12px 12px calc(12px + var(--safe-bottom));
    padding-top: calc(12px + var(--safe-top));
    min-height: 100dvh;
  }

  /* Game screen has bottom nav, so needs extra bottom padding */
  #screen-game .app-inner {
    padding-bottom: calc(var(--nav-h) + var(--safe-bottom) + 16px);
  }

  /* ── HEADER ── */
  .game-header {
    text-align: center;
    padding: 16px 0 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }

  .game-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 8vw, 3.5rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 30px rgba(201,162,39,0.4), 0 2px 4px rgba(0,0,0,0.8);
    letter-spacing: 4px;
  }

  .game-subtitle {
    color: var(--muted);
    font-style: italic;
    font-size: 0.9rem;
    margin-top: 4px;
  }

  .phase-indicator {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 14px;
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: var(--gold);
    margin-top: 8px;
  }

  /* ── PANELS ── */
  .panel {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
  }

  .panel-title {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: var(--gold);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 12px;
  }

  /* ── BUTTONS ── */
  .btn {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    /* Minimum 44px touch target per Apple HIG */
    min-height: 44px;
    padding: 10px 20px;
    border: 1px solid;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    -webkit-appearance: none;
    appearance: none;
    touch-action: manipulation;
  }

  .btn-gold {
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border-color: var(--gold-light);
    color: #1a1200;
    font-weight: 700;
  }

  .btn-gold:active { filter: brightness(0.9); }

  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text);
  }

  .btn-ghost:active { border-color: var(--gold); color: var(--gold); }

  .btn-red {
    background: var(--red);
    border-color: var(--red-bright);
    color: #ffd0d0;
  }

  .btn-red:active { background: var(--red-bright); }

  .btn-green {
    background: var(--green);
    border-color: var(--green-bright);
    color: #d0ffd8;
  }

  .btn-green:active { background: var(--green-bright); }

  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── INPUTS ── */
  input, select, textarea {
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    padding: 12px 14px;
    font-family: 'Crimson Text', serif;
    /* 16px prevents iOS zoom-on-focus */
    font-size: 16px;
    width: 100%;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    appearance: none;
    touch-action: manipulation;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  select option { background: var(--deep); }
  textarea { resize: vertical; min-height: 60px; }

  label {
    display: block;
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 6px;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.5px;
  }

  .form-group { margin-bottom: 14px; }

  /* ── ROLE REVEAL ── */
  .role-reveal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 20px;
    padding: 20px;
    padding-bottom: calc(20px + var(--safe-bottom));
    overflow-y: auto;
  }

  .role-reveal-inner {
    text-align: center;
    max-width: 380px;
    width: 100%;
    animation: revealPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }

  @keyframes revealPop {
    from { transform: scale(0.7); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .role-card-big {
    background: var(--card);
    border: 2px solid var(--gold);
    border-radius: 16px;
    padding: 24px 16px;
    box-shadow: 0 0 60px rgba(201,162,39,0.3), 0 0 120px rgba(201,162,39,0.1);
  }

  .role-card-big .role-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 6vw, 2rem);
    font-weight: 900;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .role-card-big .role-team {
    font-size: 0.85rem;
    font-family: 'Cinzel', serif;
    letter-spacing: 2px;
    padding: 4px 14px;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .team-village { background: rgba(26,107,58,0.3); color: #7dffa0; border: 1px solid var(--green-bright); }
  .team-wolf { background: rgba(122,0,0,0.4); color: #ff9090; border: 1px solid var(--red-bright); }
  .team-solo { background: rgba(74,26,107,0.4); color: #d0a0ff; border: 1px solid #7b2fbe; }
  .team-lovers { background: rgba(107,26,70,0.4); color: #ffb0d0; border: 1px solid #c0397b; }

  .role-card-big .role-desc {
    color: var(--muted);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
  }

  /* ── PLAYER GRID ── */
  .players-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 8px;
  }

  .player-tile {
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 6px;
    text-align: center;
    transition: all 0.15s;
    cursor: default;
    position: relative;
    user-select: none;
    touch-action: manipulation;
    /* Ensure minimum tap target */
    min-height: 88px;
  }

  .player-tile.dead { opacity: 0.4; filter: grayscale(1); }

  .player-tile.selectable {
    cursor: pointer;
    border-color: var(--gold);
  }

  .player-tile.selectable:active {
    background: rgba(201,162,39,0.15);
    transform: scale(0.96);
  }

  .player-tile.selected {
    border-color: var(--gold-light);
    background: rgba(201,162,39,0.2);
    box-shadow: 0 0 12px rgba(201,162,39,0.3);
  }

  .player-tile .player-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--border);
    margin: 0 auto 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    border: 2px solid var(--border);
    overflow: hidden;
  }

  .player-tile .player-avatar img {
    width: 100%; height: 100%; object-fit: cover; border-radius: 50%;
  }

  .player-tile .player-name {
    font-size: 0.72rem;
    font-family: 'Cinzel', serif;
    word-break: break-word;
    color: var(--text);
    line-height: 1.2;
  }

  .player-tile .mayor-crown {
    position: absolute;
    top: -6px; right: -6px;
    font-size: 1.1rem;
  }

  .player-tile .dead-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    background: rgba(0,0,0,0.5);
    border-radius: 10px;
  }

  /* ── CHAT ── */
  .chat-area {
    height: 220px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px;
    margin-bottom: 10px;
    scroll-behavior: smooth;
  }

  .chat-msg {
    padding: 5px 8px;
    border-radius: 6px;
    margin-bottom: 6px;
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .chat-msg .msg-author {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .chat-msg.msg-system {
    background: rgba(201,162,39,0.08);
    border-left: 2px solid var(--gold);
    color: var(--gold);
    font-style: italic;
    font-size: 0.85rem;
  }

  .chat-msg.msg-wolf { background: rgba(122,0,0,0.2); }
  .chat-msg.msg-wolf .msg-author { color: #ff8080; }
  .chat-msg.msg-normal .msg-author { color: var(--gold); }
  .chat-msg.msg-normal { background: rgba(255,255,255,0.03); }

  .chat-input-row {
    display: flex;
    gap: 8px;
  }

  .chat-input-row input { flex: 1; }

  /* Prevent chat input from being pushed up by keyboard on iOS */
  .chat-input-row .btn {
    flex-shrink: 0;
    min-width: 48px;
  }

  /* ── VOTE ── */
  .vote-timer {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    color: var(--red-bright);
    text-align: center;
    font-weight: 900;
  }

  .vote-bars { display: flex; flex-direction: column; gap: 6px; }

  .vote-bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
  }

  .vote-bar-row .vb-name {
    width: 90px;
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 0;
  }

  .vote-bar-track {
    flex: 1;
    height: 16px;
    background: var(--deep);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .vote-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--red), var(--red-bright));
    border-radius: 8px;
    transition: width 0.5s;
  }

  .vote-count {
    width: 24px;
    text-align: right;
    color: var(--muted);
    font-size: 0.82rem;
    flex-shrink: 0;
  }

  /* ── ROLE CONFIG ── */
  .role-config-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .role-config-item {
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
  }

  .role-config-item .rc-name {
    font-size: 0.82rem;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rc-counter {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .rc-counter button {
    /* Large touch target */
    width: 36px;
    height: 36px;
    background: var(--border);
    border: none;
    border-radius: 6px;
    color: var(--text);
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .rc-counter button:active { background: var(--gold); color: #000; }
  .rc-counter .rc-val {
    min-width: 28px;
    text-align: center;
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1rem;
  }

  /* ── LOBBY ── */
  .lobby-list { display: flex; flex-direction: column; gap: 8px; }

  .lobby-player {
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .lobby-player .lp-name {
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
  }

  .lobby-player .lp-host {
    font-size: 0.7rem;
    background: rgba(201,162,39,0.2);
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 3px 10px;
    border-radius: 10px;
    font-family: 'Cinzel', serif;
    white-space: nowrap;
  }

  /* ── TOAST ── */
  #toast-container {
    position: fixed;
    bottom: calc(var(--nav-h) + var(--safe-bottom) + 12px);
    right: 12px;
    left: 12px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 8px;
    pointer-events: none;
    align-items: flex-end;
  }

  .toast {
    background: var(--card);
    border: 1px solid var(--gold);
    border-radius: 10px;
    padding: 12px 16px;
    font-family: 'Cinzel', serif;
    font-size: 0.82rem;
    color: var(--gold);
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    animation: toastIn 0.3s ease, toastOut 0.3s ease 2.7s forwards;
    pointer-events: auto;
    max-width: 320px;
  }

  .toast.toast-red { border-color: var(--red-bright); color: #ff9090; }
  .toast.toast-green { border-color: var(--green-bright); color: #90ff90; }

  @keyframes toastIn { from { transform: translateX(110%); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes toastOut { to { transform: translateX(110%); opacity: 0; } }

  /* ── MAYOR ── */
  .mayor-section {
    background: rgba(201,162,39,0.08);
    border: 1px solid var(--gold);
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 12px;
  }

  .mayor-section h3 {
    font-family: 'Cinzel', serif;
    color: var(--gold);
    margin-bottom: 6px;
    font-size: 0.95rem;
  }

  /* ── BADGES ── */
  .badge {
    font-size: 0.7rem;
    font-family: 'Cinzel', serif;
    padding: 3px 10px;
    border-radius: 10px;
    letter-spacing: 0.5px;
    display: inline-block;
  }

  .badge-day { background: rgba(230,200,50,0.2); color: #ffd700; border: 1px solid #ffd700; }
  .badge-night { background: rgba(40,0,80,0.5); color: #b090ff; border: 1px solid #6040a0; }

  /* ── UTILITIES ── */
  .flex { display: flex; }
  .flex-center { display: flex; align-items: center; justify-content: center; }
  .flex-between { display: flex; align-items: center; justify-content: space-between; }
  .flex-wrap { flex-wrap: wrap; }
  .gap-8 { gap: 8px; }
  .gap-12 { gap: 12px; }
  .mb-8 { margin-bottom: 8px; }
  .mb-12 { margin-bottom: 12px; }
  .mt-8 { margin-top: 8px; }
  .text-center { text-align: center; }
  .text-muted { color: var(--muted); font-style: italic; }
  .text-gold { color: var(--gold); }
  .text-sm { font-size: 0.85rem; }

  /* ── TABS (scrollable on mobile) ── */
  .tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    padding: 10px 14px;
    cursor: pointer;
    font-family: 'Cinzel', serif;
    font-size: 0.78rem;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    letter-spacing: 0.5px;
    white-space: nowrap;
    touch-action: manipulation;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .tab.active { color: var(--gold); border-bottom-color: var(--gold); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--deep); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── RESULT SCREEN ── */
  .result-screen {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 20px;
    text-align: center;
    padding: 20px;
    padding-bottom: calc(20px + var(--safe-bottom));
    overflow-y: auto;
  }

  .result-screen h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 7vw, 3.5rem);
    font-weight: 900;
  }

  .result-wolf h1 { color: var(--red-bright); text-shadow: 0 0 30px rgba(192,57,43,0.6); }
  .result-village h1 { color: var(--gold); text-shadow: 0 0 30px rgba(201,162,39,0.6); }
  .result-solo h1 { color: #b090ff; text-shadow: 0 0 30px rgba(176,144,255,0.6); }

  /* ── ROLE IMAGE PLACEHOLDER ── */
  .role-img-placeholder {
    width: 140px;
    height: 140px;
    border-radius: 12px;
    background: var(--deep);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    margin: 0 auto 14px;
  }

  /* ── ROLE CHIP ── */
  .role-chip {
    font-size: 0.7rem;
    font-family: 'Cinzel', serif;
    padding: 3px 10px;
    background: rgba(201,162,39,0.15);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--gold);
    white-space: nowrap;
  }

  /* ── SPINNER ── */
  .spinner {
    display: inline-block;
    width: 20px; height: 20px;
    border: 2px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── NIGHT OVERLAY ── */
  .night-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 24px;
    padding: 20px;
    padding-bottom: calc(20px + var(--safe-bottom));
  }

  /* ── BOTTOM NAVIGATION (mobile game screen) ── */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: calc(var(--nav-h) + var(--safe-bottom));
    background: var(--card);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    padding-top: 0;
    padding-bottom: var(--safe-bottom);
    z-index: 500;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .bottom-nav-items {
    display: flex;
    width: 100%;
    height: var(--nav-h);
    align-items: center;
  }

  .bnav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    height: 100%;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    color: var(--muted);
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.3px;
    transition: color 0.15s;
    position: relative;
  }

  .bnav-item .bnav-icon { font-size: 1.4rem; line-height: 1; }
  .bnav-item.active { color: var(--gold); }
  .bnav-item.active::after {
    content: '';
    position: absolute;
    top: 0; left: 20%; right: 20%;
    height: 2px;
    background: var(--gold);
    border-radius: 0 0 2px 2px;
  }

  .bnav-badge {
    position: absolute;
    top: 6px;
    right: calc(50% - 20px);
    width: 8px; height: 8px;
    background: var(--red-bright);
    border-radius: 50%;
    display: none;
  }

  .bnav-badge.show { display: block; }

  /* ── MOBILE PANELS (single-column within game screen) ── */
  .game-pane { display: none; }
  .game-pane.active { display: block; }

  /* ── LOBBY LAYOUT ── */
  .lobby-layout {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── GAME LAYOUT (stacked on mobile, 2-col on desktop) ── */
  .desktop-game-cols {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── DESKTOP OVERRIDES (≥640px) ── */
  @media (min-width: 640px) {
    .lobby-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: 16px;
    }

    .bottom-nav { display: none; }

    /* All panes visible on desktop */
    .game-pane { display: block !important; }

    #screen-game .app-inner { padding-bottom: 0; }

    /* Two-column game layout on desktop */
    .desktop-game-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      align-items: start;
    }

    .chat-area { height: 260px; }
    .role-config-grid { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
    .players-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }

    #toast-container {
      bottom: 20px;
      left: auto;
    }
  }

  /* ── JOIN CODE INPUT ── */
  #join-code-input {
    text-transform: uppercase;
    letter-spacing: 6px;
    font-size: 16px;
    text-align: center;
    font-family: 'Cinzel', serif;
  }

  /* ════════════════════════════════════════
     NARRATOR / ERZÄHLER
  ════════════════════════════════════════ */
  .narrator-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.88);
    z-index: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 20px;
    padding: 24px;
    padding-bottom: calc(24px + var(--safe-bottom));
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .narrator-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .narrator-box {
    max-width: 480px;
    width: 100%;
    text-align: center;
  }

  .narrator-icon {
    font-size: 3.5rem;
    margin-bottom: 12px;
    display: block;
    filter: drop-shadow(0 0 20px rgba(201,162,39,0.5));
  }

  .narrator-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.2rem, 5vw, 1.8rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(201,162,39,0.4);
    margin-bottom: 10px;
  }

  .narrator-text {
    font-family: 'Crimson Text', serif;
    font-style: italic;
    font-size: clamp(0.95rem, 3.5vw, 1.15rem);
    color: var(--text);
    line-height: 1.65;
    min-height: 2.5em;
  }

  .narrator-countdown {
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .narrator-countdown-bar {
    width: 140px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .narrator-countdown-fill {
    height: 100%;
    background: var(--gold);
    border-radius: 2px;
    transition: width 0.9s linear;
  }

  .narrator-phase-night .narrator-title { color: #b090ff; text-shadow: 0 0 20px rgba(140,80,255,0.5); }
  .narrator-phase-wolf .narrator-title  { color: #ff7070; text-shadow: 0 0 20px rgba(200,0,0,0.5); }

  /* Night step dots */
  .night-step-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .night-step-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
    transition: all 0.3s;
  }

  .night-step-dot.done   { background: var(--gold); }
  .night-step-dot.active { background: var(--gold-light); box-shadow: 0 0 8px var(--gold); transform: scale(1.3); }

  /* Narrator pulse in header */
  .narrator-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    color: var(--muted);
    justify-content: center;
    margin-top: 6px;
  }

  .narrator-pulse {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: npulse 1.5s ease-in-out infinite;
  }

  @keyframes npulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.3; transform: scale(0.5); }
  }

  /* Action timer bar inside night-action-panel */
  .action-timer-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .action-timer-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 2px;
    transition: width 1s linear;
  }
  /* ════════════════════════════════════════
     PRE-GAME INFO SCREEN
  ════════════════════════════════════════ */
  .pregame-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.96);
    z-index: 1500;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .pregame-header {
    flex-shrink: 0;
    text-align: center;
    padding: 16px 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .pregame-header h2 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.1rem, 4vw, 1.6rem);
    font-weight: 900;
    color: var(--gold);
    margin-bottom: 3px;
  }
  .pregame-header p { color: var(--muted); font-style: italic; font-size: 0.85rem; margin-bottom: 10px; }
  .pregame-tabs { display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .pregame-tabs::-webkit-scrollbar { display: none; }
  .pregame-tab {
    padding: 9px 15px;
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    min-height: 44px;
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .pregame-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
  .pregame-body { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 14px 13px 20px; }
  .pregame-footer {
    flex-shrink: 0;
    padding: 10px 13px calc(10px + var(--safe-bottom));
    border-top: 1px solid var(--border);
    background: var(--card);
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .pregame-footer .pgf-hint { flex: 1; font-size: 0.75rem; color: var(--muted); font-style: italic; }

  /* Night sequence */
  .night-sequence-list { display: flex; flex-direction: column; gap: 6px; }
  .night-seq-item {
    display: flex; align-items: flex-start; gap: 10px;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 10px; padding: 11px 12px; position: relative;
  }
  .night-seq-item.seq-wolf    { border-color: rgba(192,57,43,0.45); background: rgba(100,0,0,0.12); }
  .night-seq-item.seq-special { border-color: rgba(74,26,107,0.5);  background: rgba(74,26,107,0.1); }
  .night-seq-item.seq-inactive { opacity: 0.3; filter: grayscale(0.6); }
  .seq-num { font-family: 'Cinzel', serif; font-size: 0.62rem; color: var(--muted); width: 16px; flex-shrink: 0; padding-top: 3px; text-align: right; }
  .seq-icon { font-size: 1.4rem; flex-shrink: 0; line-height: 1; }
  .seq-body { flex: 1; min-width: 0; }
  .seq-title { font-family: 'Cinzel', serif; font-size: 0.84rem; font-weight: 700; color: var(--text); margin-bottom: 2px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .seq-cond { font-size: 0.68rem; color: var(--gold); background: rgba(201,162,39,0.1); border: 1px solid rgba(201,162,39,0.3); border-radius: 8px; padding: 1px 7px; font-style: italic; white-space: nowrap; }
  .seq-cond.cond-night1 { color: #a0d0ff; background: rgba(100,160,255,0.1); border-color: rgba(100,160,255,0.3); }
  .seq-action { font-size: 0.8rem; color: var(--text); line-height: 1.4; margin-top: 3px; }
  .seq-desc   { font-size: 0.78rem; color: var(--muted); font-style: italic; line-height: 1.4; margin-top: 2px; }
  .seq-timer  { font-family: 'Cinzel', serif; font-size: 0.62rem; color: var(--muted); flex-shrink: 0; align-self: flex-start; background: var(--deep); border: 1px solid var(--border); border-radius: 6px; padding: 3px 7px; margin-top: 2px; }
  .seq-not-in-game { position: absolute; top: 7px; right: 9px; font-size: 0.6rem; font-family: 'Cinzel', serif; color: var(--muted); background: var(--deep); border: 1px solid var(--border); border-radius: 5px; padding: 2px 6px; }
  .seq-legend { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; padding: 8px 12px; background: var(--card); border: 1px solid var(--border); border-radius: 8px; }
  .seq-legend span { display: flex; align-items: center; gap: 5px; font-size: 0.71rem; font-family: 'Cinzel', serif; color: var(--muted); }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
  .legend-dot.dot-normal  { background: var(--card); border: 1px solid var(--border); }
  .legend-dot.dot-wolf    { background: rgba(100,0,0,0.4); border: 1px solid var(--red-bright); }
  .legend-dot.dot-special { background: rgba(74,26,107,0.4); border: 1px solid #7b2fbe; }
  .legend-dot.dot-off     { background: var(--deep); border: 1px solid var(--border); opacity: 0.35; }

  /* Role cards */
  .role-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(148px, 1fr)); gap: 9px; }
  @media (max-width: 380px) { .role-cards-grid { grid-template-columns: 1fr 1fr; } }
  .role-info-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 11px 10px; text-align: center; }
  .role-info-card.rc-wolf   { border-color: rgba(192,57,43,0.4); background: rgba(100,0,0,0.1); }
  .role-info-card.rc-solo   { border-color: rgba(74,26,107,0.5); background: rgba(74,26,107,0.08); }
  .ric-emoji { font-size: 1.9rem; display: block; margin-bottom: 5px; }
  .ric-name  { font-family: 'Cinzel', serif; font-size: 0.75rem; font-weight: 700; color: var(--gold); margin-bottom: 3px; }
  .ric-count { font-family: 'Cinzel', serif; font-size: 0.62rem; color: var(--muted); background: var(--deep); border-radius: 6px; padding: 2px 7px; margin-bottom: 5px; display: inline-block; }
  .ric-team  { font-size: 0.64rem; font-family: 'Cinzel', serif; padding: 2px 8px; border-radius: 8px; display: inline-block; margin-bottom: 6px; }
  .ric-village { background: rgba(26,107,58,0.25); color: #7dffa0; border: 1px solid rgba(39,174,96,0.35); }
  .ric-wolf-t  { background: rgba(122,0,0,0.3);   color: #ff9090; border: 1px solid rgba(192,57,43,0.4); }
  .ric-solo-t  { background: rgba(74,26,107,0.3); color: #d0a0ff; border: 1px solid rgba(123,47,190,0.4); }
  .ric-desc    { font-size: 0.75rem; color: var(--muted); font-style: italic; line-height: 1.4; margin-bottom: 6px; }
  .ric-ability { font-size: 0.73rem; color: var(--text); background: var(--deep); border-radius: 6px; padding: 5px 8px; line-height: 1.4; text-align: left; border: 1px solid var(--border); }
  .ric-night-tag { font-size: 0.62rem; font-family: 'Cinzel', serif; color: #b090ff; background: rgba(74,26,107,0.2); border: 1px solid rgba(74,26,107,0.4); border-radius: 6px; padding: 2px 7px; display: inline-block; margin-bottom: 5px; }


  /* ── TIMER SETTINGS ── */
  .timer-settings {
    background: var(--deep);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 10px;
  }
  .timer-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .timer-row:last-child { margin-bottom: 0; }
  .timer-label {
    flex: 1;
    font-size: 0.82rem;
    color: var(--text);
    font-family: 'Cinzel', serif;
    min-width: 0;
  }
  .timer-label small { display: block; font-family: 'Crimson Text', serif; color: var(--muted); font-size: 0.72rem; font-style: italic; }
  .timer-presets {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }
  .timer-preset {
    background: var(--border);
    border: 1px solid transparent;
    border-radius: 6px;
    color: var(--muted);
    font-family: 'Cinzel', serif;
    font-size: 0.68rem;
    padding: 4px 8px;
    cursor: pointer;
    touch-action: manipulation;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .timer-preset.active {
    background: rgba(201,162,39,0.2);
    border-color: var(--gold);
    color: var(--gold);
  }
  .timer-preset:active { transform: scale(0.95); }
  .timer-custom-input {
    width: 58px !important;
    padding: 6px 8px !important;
    font-size: 14px !important;
    text-align: center;
    font-family: 'Cinzel', serif !important;
    flex-shrink: 0;
  }

  /* ── IMPROVED VOTE PANEL ── */
  .vote-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .vote-panel-title {
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
    color: var(--gold);
  }
  .vote-clock {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .vote-clock-ring {
    position: relative;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }
  .vote-clock-ring svg {
    position: absolute;
    top: 0; left: 0;
    transform: rotate(-90deg);
  }
  .vote-clock-ring circle {
    fill: none;
    stroke-width: 3;
  }
  .vote-clock-bg   { stroke: var(--border); }
  .vote-clock-fill {
    stroke: var(--red-bright);
    stroke-linecap: round;
    transition: stroke-dashoffset 1s linear, stroke 0.5s;
  }
  .vote-clock-fill.urgent { stroke: var(--red-bright); }
  .vote-clock-fill.ok     { stroke: var(--gold); }
  .vote-clock-num {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cinzel', serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text);
  }
  .vote-progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .vote-progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 1s linear, background 0.5s;
  }
  .vote-bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 8px;
    margin-bottom: 4px;
    background: var(--deep);
    border: 1px solid transparent;
    transition: all 0.3s;
    cursor: pointer;
    touch-action: manipulation;
  }
  .vote-bar-row.voted-for {
    border-color: var(--gold);
    background: rgba(201,162,39,0.1);
  }
  .vote-bar-row.leading {
    border-color: rgba(192,57,43,0.4);
  }
  .vote-bar-row .vb-avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .vote-bar-row .vb-name {
    width: 80px;
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 0;
  }
  .vote-bar-track {
    flex: 1;
    height: 14px;
    background: rgba(255,255,255,0.06);
    border-radius: 7px;
    overflow: hidden;
  }
  .vote-bar-fill {
    height: 100%;
    border-radius: 7px;
    transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
    background: linear-gradient(90deg, var(--red), var(--red-bright));
  }
  .vote-bar-fill.fill-lead { background: linear-gradient(90deg, #8b0000, #c0392b); }
  .vote-count {
    width: 20px;
    text-align: right;
    font-family: 'Cinzel', serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text);
    flex-shrink: 0;
  }
  .vote-mayor-badge {
    font-size: 0.6rem;
    background: rgba(201,162,39,0.2);
    border: 1px solid var(--gold);
    border-radius: 4px;
    padding: 1px 4px;
    color: var(--gold);
    font-family: 'Cinzel', serif;
    flex-shrink: 0;
  }
  .vote-summary {
    margin-top: 10px;
    padding: 8px 10px;
    background: var(--deep);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.78rem;
    color: var(--muted);
    font-family: 'Cinzel', serif;
  }
  .vote-summary .vs-done { color: var(--gold); }
  .vote-your-choice {
    margin-top: 8px;
    text-align: center;
    font-size: 0.78rem;
    font-style: italic;
    color: var(--muted);
  }
  .vote-your-choice .vyc-name { color: var(--gold); font-style: normal; }
  .vote-end-btn {
    margin-top: 10px;
    width: 100%;
  }
</style>
</head>
<body>

<!-- Village SVG Background -->
<div id="village-bg">
<svg viewBox="0 0 1200 700" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
  <!-- Sky gradient -->
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#050510"/>
      <stop offset="100%" stop-color="#1a0a2e"/>
    </linearGradient>
    <radialGradient id="moon-glow" cx="50%" cy="20%" r="30%">
      <stop offset="0%" stop-color="#ffe0a0" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="transparent"/>
    </radialGradient>
  </defs>
  <rect width="1200" height="700" fill="url(#sky)"/>
  <rect width="1200" height="700" fill="url(#moon-glow)"/>
  <!-- Moon -->
  <circle cx="600" cy="120" r="45" fill="#fff8e8" opacity="0.9"/>
  <circle cx="620" cy="105" r="38" fill="#1a0a2e" opacity="0.9"/>
  <!-- Stars -->
  <circle cx="100" cy="60" r="1.5" fill="white" opacity="0.8"/>
  <circle cx="200" cy="40" r="1" fill="white" opacity="0.6"/>
  <circle cx="350" cy="80" r="2" fill="white" opacity="0.9"/>
  <circle cx="450" cy="30" r="1" fill="white" opacity="0.7"/>
  <circle cx="750" cy="50" r="1.5" fill="white" opacity="0.8"/>
  <circle cx="900" cy="70" r="1" fill="white" opacity="0.6"/>
  <circle cx="1050" cy="35" r="2" fill="white" opacity="0.7"/>
  <circle cx="1150" cy="90" r="1.5" fill="white" opacity="0.8"/>
  <circle cx="280" cy="110" r="1" fill="white" opacity="0.5"/>
  <circle cx="820" cy="100" r="1.5" fill="white" opacity="0.6"/>
  <!-- Ground -->
  <rect x="0" y="580" width="1200" height="120" fill="#0d0d1a"/>
  <!-- Far tree line -->
  <rect x="0" y="470" width="1200" height="130" fill="#0a0a18" opacity="0.6"/>
  <!-- Houses -->
  <!-- House 1 left -->
  <rect x="80" y="420" width="100" height="160" fill="#13132a"/>
  <polygon points="80,420 180,420 130,350" fill="#1a0a2e"/>
  <rect x="110" y="480" width="30" height="50" fill="#2a1a10"/>
  <rect x="100" y="430" width="20" height="20" fill="#3a2a00" opacity="0.7"/>
  <rect x="150" y="430" width="20" height="20" fill="#3a2a00" opacity="0.7"/>
  <!-- Chimney smoke -->
